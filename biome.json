{
  "$schema": "https://biomejs.dev/schemas/1.9.4/schema.json",
  "formatter": {
    "indentStyle": "space",
    "indentWidth": 2
  },
  "organizeImports": {
    "enabled": true
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "complexity": {
        "noForEach": "off",
        "useLiteralKeys": "off"
      },
      "performance": {
        "noDelete": "off"
      }
    }
  },
  "files": {
    "ignore": [
      "packages/*/node_modules",
      "packages/*/build",
      "packages/*/dist",
      "packages/*/artifacts"
    ]
  }
}

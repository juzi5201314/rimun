{
  "name": "@rimun/desktop",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bunx electrobun dev",
    "dev:cdp": "bash ./scripts/with-cef-automation-env.sh dev",
    "dev:host": "bun run src/bun/dev-host.ts",
    "dev:watch": "bunx electrobun dev --watch",
    "dev:watch:cdp": "bash ./scripts/with-cef-automation-env.sh dev --watch",
    "run": "bunx electrobun run",
    "build": "bunx electrobun build --env=stable",
    "build:dev": "bunx electrobun build --env=dev",
    "build:test:cdp": "bash ./scripts/with-cef-automation-env.sh build --env=test",
    "test": "bun test",
    "check": "bunx tsc --noEmit"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.58",
    "@ai-sdk/google": "^3.0.43",
    "@ai-sdk/openai": "^3.0.41",
    "@iarna/toml": "^3.0.0",
    "@rimun/domain": "workspace:*",
    "@rimun/shared": "workspace:*",
    "ai": "^6.0.116",
    "drizzle-orm": "^0.44.5",
    "electrobun": "1.15.1",
    "p-limit": "^7.3.0",
    "saxes": "^6.0.0"
  },
  "devDependencies": {
    "@types/bun": "latest"
  }
}

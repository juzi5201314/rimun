{
  "name": "rimun",
  "version": "0.1.0",
  "private": true,
  "packageManager": "bun@1.3.10",
  "workspaces": ["packages/*"],
  "scripts": {
    "dev": "bun run ./tools/dev.ts --mode auto",
    "dev:cdp": "bun run ./tools/dev.ts --mode auto --cef-automation",
    "dev:web": "bun run ./tools/dev.ts --mode web",
    "bench:localization:real": "bun run --cwd packages/desktop bench:localization:real",
    "build": "bun run ./tools/build.ts",
    "build:desktop:test:cdp": "bun run --cwd packages/desktop build:test:cdp",
    "test": "bun run ./tools/test.ts",
    "typecheck": "bun run ./tools/typecheck.ts",
    "lint": "bunx biome check .",
    "check": "bun run typecheck && bun run lint && bun run test",
    "format": "bunx biome format --write ."
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@biomejs/biome": "^1.9.4",
    "typescript": "^5.9.2"
  }
}

{
  "name": "rimun",
  "version": "0.1.0",
  "private": true,
  "packageManager": "bun@1.3.10",
  "workspaces": ["packages/*"],
  "scripts": {
    "dev": "bash ./tools/dev.sh",
    "dev:cdp": "RIMUN_ENABLE_CEF_AUTOMATION=1 bash ./tools/dev.sh",
    "dev:web": "RIMUN_DEV_MODE=web bash ./tools/dev.sh",
    "build": "bash ./tools/build.sh",
    "build:desktop:test:cdp": "bun --cwd packages/desktop run build:test:cdp",
    "test": "bash ./tools/test.sh",
    "typecheck": "bash ./tools/typecheck.sh",
    "lint": "biome check .",
    "check": "bun run typecheck && bun run lint && bun run test",
    "format": "biome format --write ."
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@biomejs/biome": "^1.9.4",
    "typescript": "^5.9.2"
  }
}
